{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Platform/fleet reference dashboard for github-actions-gateway (Q186). Sourced from the GMC manager metrics (single cluster-wide TLS scrape): managed gateways, GMC reconcile health, and the cross-tenant condition rollups (RunnerGroupsDegraded, EgressRulesStale, Proxy quota). The Cross-tenant Throughput row additionally requires the per-tenant AGC scrapes. For a single tenant's detail see grafana-dashboard-tenant.json. See docs/operations/observability.md.",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["actions-gateway"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(actions_gateway_active_sessions, namespace)",
        "hide": 0,
        "includeAll": true,
        "label": "Namespace",
        "multi": true,
        "name": "namespace",
        "query": {
          "query": "label_values(actions_gateway_active_sessions, namespace)",
          "refId": "namespace"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "Actions Gateway — Platform",
  "uid": "actions-gateway-platform",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "Fleet Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Managed gateways",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "description": "ActionsGateway CRs currently managed by the GMC.",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway_managed_gateways",
          "legendFormat": "managed",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Degraded gateways",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "description": "Gateways reporting RunnerGroupsDegraded=True (one or more owned RunnerGroups impaired).",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(actions_gateway_runnergroups_degraded)",
          "legendFormat": "degraded",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Egress allowlist stale",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "description": "Gateways reporting EgressRulesStale=True (GitHub egress IP-range allowlist not refreshed within the staleness window).",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(actions_gateway_egress_rules_stale)",
          "legendFormat": "egress stale",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Proxy quota exceeded",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "description": "Gateways reporting ProxyQuotaExceeded=True (proxy replica creation rejected by the namespace ResourceQuota).",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(actions_gateway_proxy_quota_exceeded)",
          "legendFormat": "proxy quota exceeded",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "GMC Control Plane",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 10,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Reconcile errors by controller",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 8 },
      "id": 11,
      "description": "controller_runtime_reconcile_errors_total — non-zero sustained rate indicates a controller issue.",
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_errors_total[5m]))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reconcile rate by controller",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 8 },
      "id": 12,
      "description": "controller_runtime_reconcile_total — overall reconcile throughput per controller.",
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_total[5m]))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "IP range refreshes (24h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 8 },
      "id": 13,
      "description": "NetworkPolicy egress-rule refreshes applied from the GitHub meta API across all tenants.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(actions_gateway_ip_range_updates_total[24h]))",
          "legendFormat": "refreshes",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Fleet Conditions (per gateway)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 20,
      "panels": []
    },
    {
      "type": "state-timeline",
      "title": "Gateway condition rollups",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 21,
      "description": "GMC-exported condition gauges (1=firing) per gateway: RunnerGroupsDegraded, EgressRulesStale, ProxyQuotaPressure, ProxyQuotaExceeded.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "FIRING", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "showValue": "never", "mergeValues": true, "alignValue": "center", "rowHeight": 0.9, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway_runnergroups_degraded",
          "legendFormat": "degraded {{namespace}}/{{name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway_egress_rules_stale",
          "legendFormat": "egress stale {{namespace}}/{{name}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway_proxy_quota_pressure",
          "legendFormat": "proxy quota pressure {{namespace}}/{{name}}",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway_proxy_quota_exceeded",
          "legendFormat": "proxy quota exceeded {{namespace}}/{{name}}",
          "refId": "D"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cross-tenant Throughput (requires per-tenant scrape)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 30,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Active sessions by namespace",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 25 },
      "id": 31,
      "description": "Requires the per-tenant AGC scrapes (mTLS). Empty if only the GMC manager is scraped.",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (namespace) (actions_gateway_active_sessions{namespace=~\"$namespace\"})",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Jobs acquired/min by namespace",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 25 },
      "id": 32,
      "description": "Requires the per-tenant AGC scrapes (mTLS).",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (namespace) (rate(actions_gateway_jobs_acquired_total{namespace=~\"$namespace\"}[5m])) * 60",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pod creation p99 by namespace",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 25 },
      "id": 33,
      "description": "From the actions_gateway:pod_creation_latency_seconds:p99 recording rule. Requires the per-tenant AGC scrapes.",
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway:pod_creation_latency_seconds:p99{namespace=~\"$namespace\"}",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    }
  ]
}
