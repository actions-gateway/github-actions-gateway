{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-tenant reference dashboard for github-actions-gateway (Q186). Sourced from a tenant's AGC + egress-proxy metrics (per-tenant mTLS scrape): gateway health, pod-creation-latency SLO, job throughput, tenant health conditions, egress proxy, and kube-state-metrics proxy/quota. Uses the SLO recording rules from deploy/monitoring/prometheusrule.yaml where applicable. For the fleet view see grafana-dashboard-platform.json. See docs/operations/observability.md.",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["actions-gateway"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(actions_gateway_active_sessions, namespace)",
        "hide": 0,
        "includeAll": true,
        "label": "Namespace",
        "multi": true,
        "name": "namespace",
        "query": {
          "query": "label_values(actions_gateway_active_sessions, namespace)",
          "refId": "namespace"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(actions_gateway_active_sessions{namespace=~\"$namespace\"}, runner_group)",
        "hide": 0,
        "includeAll": true,
        "label": "Runner group",
        "multi": true,
        "name": "runner_group",
        "query": {
          "query": "label_values(actions_gateway_active_sessions{namespace=~\"$namespace\"}, runner_group)",
          "refId": "runner_group"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "Actions Gateway — Tenant",
  "uid": "actions-gateway-tenant",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "Gateway Health (per namespace)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Active sessions",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (namespace, runner_group) (actions_gateway_active_sessions{namespace=~\"$namespace\", runner_group=~\"$runner_group\"})",
          "legendFormat": "{{namespace}}/{{runner_group}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Jobs acquired/min",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (namespace, runner_group) (rate(actions_gateway_jobs_acquired_total{namespace=~\"$namespace\", runner_group=~\"$runner_group\"}[5m])) * 60",
          "legendFormat": "{{namespace}}/{{runner_group}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Token refresh errors",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.0001 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (namespace) (rate(actions_gateway_token_refresh_errors_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "RenewJob errors",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.0001 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (namespace) (rate(actions_gateway_renew_job_errors_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Pod Creation Latency SLO",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 10,
      "panels": []
    },
    {
      "type": "gauge",
      "title": "p95 pod creation latency",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 8 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway:pod_creation_latency_seconds:p95{namespace=~\"$namespace\"}",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "p99 pod creation latency",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 8 },
      "id": 12,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway:pod_creation_latency_seconds:p99{namespace=~\"$namespace\"}",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Pod creation latency heatmap",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "id": 13,
      "options": { "calculate": false, "cellGap": 1, "yAxis": { "unit": "s" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (le) (rate(actions_gateway_pod_creation_latency_seconds_bucket{namespace=~\"$namespace\"}[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Job Throughput (per runner_group)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 20,
      "panels": []
    },
    {
      "type": "barchart",
      "title": "Jobs acquired (1h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 16 },
      "id": 21,
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (runner_group) (increase(actions_gateway_jobs_acquired_total{namespace=~\"$namespace\", runner_group=~\"$runner_group\"}[1h]))",
          "legendFormat": "{{runner_group}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job duration p50 / p95",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 16 },
      "id": 22,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway:job_duration_seconds:p50{namespace=~\"$namespace\", runner_group=~\"$runner_group\"}",
          "legendFormat": "p50 {{namespace}}/{{runner_group}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "actions_gateway:job_duration_seconds:p95{namespace=~\"$namespace\", runner_group=~\"$runner_group\"}",
          "legendFormat": "p95 {{namespace}}/{{runner_group}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Eviction retries (1h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 16 },
      "id": 23,
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (runner_group) (increase(actions_gateway_eviction_retries_total{namespace=~\"$namespace\", runner_group=~\"$runner_group\"}[1h]))",
          "legendFormat": "{{runner_group}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Eviction budget exhausted (1h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 16 },
      "id": 24,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (namespace, runner_group) (increase(actions_gateway_eviction_retries_exhausted_total{namespace=~\"$namespace\", runner_group=~\"$runner_group\"}[1h]))",
          "legendFormat": "{{namespace}}/{{runner_group}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Tenant Health Conditions",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 50,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Worker quota exceeded",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 24 },
      "id": 51,
      "description": "1 when WorkerQuotaExceeded=True: the namespace ResourceQuota cannot admit another worker pod.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "EXCEEDED", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(actions_gateway_worker_quota_exceeded{namespace=~\"$namespace\", runner_group=~\"$runner_group\"})",
          "legendFormat": "worker quota exceeded",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Workers unschedulable",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 24 },
      "id": 52,
      "description": "1 when WorkersUnschedulable=True: worker pods are stuck Pending because the scheduler cannot place them.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "STUCK", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(actions_gateway_workers_unschedulable{namespace=~\"$namespace\", runner_group=~\"$runner_group\"})",
          "legendFormat": "workers unschedulable",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Worker quota pressure",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 24 },
      "id": 53,
      "description": "1 when WorkerQuotaPressure=True: workers cannot scale to the configured ceiling within the ResourceQuota headroom.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "PRESSURE", "color": "yellow" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(actions_gateway_worker_quota_pressure{namespace=~\"$namespace\", runner_group=~\"$runner_group\"})",
          "legendFormat": "worker quota pressure",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent recycle errors",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 24 },
      "id": 54,
      "description": "Failed single-use JIT agent re-registrations. Sustained growth shrinks listener capacity.",
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (runner_group) (rate(actions_gateway_agent_recycle_errors_total{namespace=~\"$namespace\", runner_group=~\"$runner_group\"}[5m]))",
          "legendFormat": "{{runner_group}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Egress Proxy (per tenant)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 60,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Active CONNECT tunnels",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 31 },
      "id": 61,
      "description": "Proxy metrics carry no intrinsic namespace label; attach one via the ServiceMonitor for per-tenant attribution.",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(actions_gateway_proxy_connections_active)",
          "legendFormat": "active tunnels",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CONNECT tunnels opened/s",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 31 },
      "id": 62,
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(actions_gateway_proxy_connections_total[5m]))",
          "legendFormat": "opened/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Proxy dial errors/s",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 31 },
      "id": 63,
      "description": "Upstream dial failures (e.g. blocked-destination attempts).",
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(actions_gateway_proxy_dial_errors_total[5m]))",
          "legendFormat": "dial errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tunnel duration p95",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 31 },
      "id": 64,
      "description": "p95 CONNECT tunnel lifetime, observed at close. Buckets reach the 6h absolute lifetime cap.",
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(actions_gateway_proxy_tunnel_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 tunnel duration",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Proxy & Quota (kube-state-metrics)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 30,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Proxy replicas ready",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 39 },
      "id": 31,
      "description": "Requires kube-state-metrics.",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "kube_deployment_status_replicas_ready{namespace=~\"$namespace\", deployment=\"actions-gateway-proxy\"}",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Proxy HPA desired vs current",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 39 },
      "id": 32,
      "description": "Requires kube-state-metrics.",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=~\"$namespace\"}",
          "legendFormat": "desired {{horizontalpodautoscaler}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"$namespace\"}",
          "legendFormat": "current {{horizontalpodautoscaler}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "ResourceQuota usage",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 39 },
      "id": 33,
      "description": "Requires kube-state-metrics.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "kube_resourcequota{namespace=~\"$namespace\", type=\"used\"}",
          "legendFormat": "{{namespace}} {{resource}}",
          "refId": "A"
        }
      ]
    }
  ]
}
