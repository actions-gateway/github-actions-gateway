.context
# Claude Code: default-ignore .claude/ runtime artifacts, allowlist shareable
# config back in. (.claude/* not .claude/ — git won't descend into a fully
# ignored dir, so the negations would be dead.)
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/agents/
!.claude/skills/
!.claude/hooks/
# Credentials never tracked, even if nested in an allowlisted dir (last match wins).
.claude/**/.credentials.json
CLAUDE.local.md
# binary build output
/.build/
# Local-build of the fakegithub helper (`make` at repo root drops it here);
# root-anchored so it doesn't shadow the test/fakegithub/ source directory.
/fakegithub
# stray binaries — always build via make build-* into .build/ instead
/cmd/agc/agc
/cmd/gmc/gmc
/cmd/probe/probe
/cmd/proxy/proxy
/cmd/worker/worker
