.context
# Claude Code: default-ignore .claude/ runtime artifacts, allowlist shareable
# config back in. (.claude/* not .claude/ — git won't descend into a fully
# ignored dir, so the negations would be dead.)
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/agents/
!.claude/skills/
!.claude/hooks/
# Credentials never tracked, even if nested in an allowlisted dir (last match wins).
.claude/**/.credentials.json
CLAUDE.local.md
# Scratch space for agent/dev temp files — keeps cp/mv/tee/rm and `>` redirects
# inside the workspace so claude-workspace-guard doesn't prompt. The .gitkeep is
# tracked so the dir exists on clone; everything else here is never tracked.
/tmp/*
!/tmp/.gitkeep
# binary build output
/.build/
# MkDocs site build output (CI builds to _site; local `mkdocs build` defaults to site/)
/site/
/_site/
# Local-build of the fakegithub helper (`make` at repo root drops it here);
# root-anchored so it doesn't shadow the test/fakegithub/ source directory.
/fakegithub
# stray binaries — always build via make build-* into .build/ instead
/cmd/agc/agc
/cmd/gmc/gmc
/cmd/probe/probe
/cmd/proxy/proxy
/cmd/worker/worker
# Python virtualenv + bytecode for the claude-usage/ charting scripts
# (README creates a .venv to install matplotlib/numpy). Unanchored so a venv
# under claude-usage/ is covered too; the committed data/ and charts/ outputs
# are not affected.
.venv/
__pycache__/
*.pyc
# Go coverage profiles from a manual `go test -coverprofile`. scripts/coverage.sh
# writes its profiles to TMPDIR, never in-tree; this only catches stray manual
# runs. The committed coverage-baseline.txt (the ratchet floor) is NOT a profile
# and is intentionally tracked.
*.cover.out
coverage.out
cover.out
